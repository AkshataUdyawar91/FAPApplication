{
  "type": "AdaptiveCard",
  "version": "1.4",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Review Details — ${submissionNumber}",
              "size": "Medium",
              "weight": "Bolder",
              "color": "Accent"
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "Status: ${currentStatus}",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Right"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "attention",
      "separator": true,
      "$when": "${isAlreadyProcessed}",
      "items": [
        {
          "type": "TextBlock",
          "text": "⚠️ Already processed by ${processedBy} on ${processedAt}",
          "wrap": true,
          "weight": "Bolder",
          "size": "Small"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Validation Checks",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "FactSet",
      "facts": ${checkGroupsFacts}
    },
    {
      "type": "ActionSet",
      "separator": true,
      "$when": "${!isAlreadyProcessed}",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Approve",
          "style": "positive",
          "data": {
            "action": "approve_from_review",
            "submissionId": "${submissionId}",
            "fapId": "${submissionId}",
            "cardVersion": "1.0"
          }
        },
        {
          "type": "Action.Submit",
          "title": "Reject",
          "style": "destructive",
          "data": {
            "action": "reject_from_review",
            "submissionId": "${submissionId}",
            "fapId": "${submissionId}",
            "cardVersion": "1.0"
          }
        },
        {
          "type": "Action.OpenUrl",
          "title": "Open in Portal",
          "url": "${portalUrl}"
        }
      ]
    },
    {
      "type": "ActionSet",
      "separator": true,
      "$when": "${isAlreadyProcessed}",
      "actions": [
        {
          "type": "Action.OpenUrl",
          "title": "Open in Portal",
          "url": "${portalUrl}"
        }
      ]
    }
  ]
}

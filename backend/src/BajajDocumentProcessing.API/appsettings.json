{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "<YOUR_JWT_SECRET_KEY>",
    "Issuer": "BajajDocumentProcessing",
    "Audience": "BajajDocumentProcessing",
    "ExpiryMinutes": 30
  },
  "ConnectionStrings": {
    "DefaultConnection": "<YOUR_SQL_CONNECTION_STRING>"
  },
  "AzureOpenAI": {
    "Endpoint": "<YOUR_AZURE_OPENAI_ENDPOINT>",
    "ApiKey": "<YOUR_AZURE_OPENAI_API_KEY>",
    "DeploymentName": "gpt-5-mini",
    "EmbeddingDeploymentName": "text-embedding-ada-002"
  },
  "AzureDocumentIntelligence": {
    "Endpoint": "<YOUR_AZURE_DOC_INTELLIGENCE_ENDPOINT>",
    "ApiKey": "<YOUR_AZURE_DOC_INTELLIGENCE_API_KEY>"
  },
  "AzureBlobStorage": {
    "ConnectionString": "<YOUR_AZURE_BLOB_STORAGE_CONNECTION_STRING>",
    "ContainerName": "documents"
  },
  "AzureAISearch": {
    "Endpoint": "",
    "ApiKey": "",
    "IndexName": "analytics-embeddings"
  },
  "AzureCommunicationServices": {
    "ConnectionString": ""
  },
  "SAP": {
    "BaseUrl": "https://sap-api.example.com",
    "ApiKey": "",
    "Username": "",
    "Password": ""
  },
  "Smtp": {
    "Host": "<YOUR_SMTP_HOST>",
    "Port": 587,
    "Username": "<YOUR_SMTP_USERNAME>",
    "Password": "<YOUR_SMTP_PASSWORD>",
    "SenderEmail": "<YOUR_SENDER_EMAIL>",
    "SenderName": "Bajaj FAP System",
    "EnableSsl": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  }
}
